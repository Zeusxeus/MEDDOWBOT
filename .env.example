# ── Environment ─────────────────────────────────────────────
MB_ENV=development

# ── Bot ─────────────────────────────────────────────────────
MB_BOT__TOKEN=your_bot_token_here
MB_BOT__WEBHOOK_URL=https://yourdomain.com
MB_BOT__WEBHOOK_SECRET=generate_random_32_chars_here
MB_BOT__ADMIN_IDS=your_telegram_user_id

# ── Local Bot API (removes 50MB limit) ──────────────────────
MB_LOCAL_API__ENABLED=true
MB_LOCAL_API__URL=http://telegram-bot-api:8081
MB_LOCAL_API__API_ID=your_api_id_here
MB_LOCAL_API__API_HASH=your_api_hash_here

# ── Database ────────────────────────────────────────────────
MB_DATABASE__URL=sqlite+aiosqlite:///./dev.db
# Prod: postgresql+asyncpg://bot:password@postgres:5432/mediabot

# ── Redis ───────────────────────────────────────────────────
MB_REDIS__URL=redis://localhost:6379/0

# ── Workers ─────────────────────────────────────────────────
MB_WORKER__CONCURRENCY=3
MB_WORKER__MAX_RETRIES=3
MB_WORKER__RETRY_DELAY=30
MB_WORKER__JOB_TIMEOUT=600

# ── Rate Limiting ───────────────────────────────────────────
MB_RATE_LIMIT__REQUESTS_PER_MINUTE=10
MB_RATE_LIMIT__BURST=3
MB_RATE_LIMIT__MAX_CONCURRENT_JOBS=2

# ── Disk ────────────────────────────────────────────────────
MB_DISK__DOWNLOADS_PATH=data/downloads
MB_DISK__TEMP_PATH=data/temp
MB_DISK__MAX_DISK_USAGE_GB=10.0
MB_DISK__MIN_FREE_GB=2.0

# ── FFmpeg ──────────────────────────────────────────────────
MB_FFMPEG__BINARY_PATH=ffmpeg
MB_FFMPEG__TARGET_MB=45
MB_FFMPEG__MAX_SIZE_MB=49
MB_FFMPEG__LARGE_FILE_WARN_MB=200

# ── Proxy Pool ──────────────────────────────────────────────
MB_PROXY__ENABLED=false
MB_PROXY__FORCE_PROXY_PLATFORMS=youtube.com,youtu.be
MB_PROXY__ROTATION_STRATEGY=round_robin
MB_PROXY__HEALTH_CHECK_INTERVAL_SECONDS=300
MB_PROXY__MAX_CONSECUTIVE_FAILURES=3
MB_PROXY__DEAD_PROXY_COOLDOWN=600

# ── Cookies ─────────────────────────────────────────────────
MB_COOKIES__ENABLED=false
MB_COOKIES__COOKIES_DIR=data/cookies
MB_COOKIES__VALIDATE_ON_STARTUP=false

# ── Observability ───────────────────────────────────────────
MB_OBS__LOG_LEVEL=INFO
MB_OBS__METRICS_PORT=9090

# ── Docker PostgreSQL ───────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Reddit ──────────────────────────────────────────────────
MB_REDDIT__ENABLED=false
MB_REDDIT__USER_AGENT=MEDDOWBOT/1.0.0
