# ── Environment ─────────────────────────────────────────────
MEDDOW_ENV=development

# ── Bot ─────────────────────────────────────────────────────
MEDDOW_BOT__TOKEN=your_bot_token_here
MEDDOW_BOT__WEBHOOK_URL=https://yourdomain.com
MEDDOW_BOT__WEBHOOK_SECRET=generate_random_32_chars_here
MEDDOW_BOT__ADMIN_IDS=your_telegram_user_id

# ── Local Bot API (removes 50MB limit) ──────────────────────
MEDDOW_LOCAL_API__ENABLED=true
MEDDOW_LOCAL_API__URL=http://telegram-bot-api:8081
MEDDOW_LOCAL_API__API_ID=your_api_id_here
MEDDOW_LOCAL_API__API_HASH=your_api_hash_here

# ── Database ────────────────────────────────────────────────
MEDDOW_DATABASE__URL=sqlite+aiosqlite:///./dev.db
# Prod: postgresql+asyncpg://bot:password@postgres:5432/mediabot

# ── Redis ───────────────────────────────────────────────────
MEDDOW_REDIS__URL=redis://localhost:6379/0

# ── Workers ─────────────────────────────────────────────────
MEDDOW_WORKER__CONCURRENCY=3
MEDDOW_WORKER__MAX_RETRIES=3
MEDDOW_WORKER__RETRY_DELAY=30
MEDDOW_WORKER__JOB_TIMEOUT=600

# ── Rate Limiting ───────────────────────────────────────────
MEDDOW_RATE_LIMIT__PER_HOUR=10
MEDDOW_RATE_LIMIT__BURST=3
MEDDOW_RATE_LIMIT__MAX_CONCURRENT_JOBS=2

# ── Disk ────────────────────────────────────────────────────
MEDDOW_DISK__TMP_DIR=/tmp/bot
MEDDOW_DISK__MIN_FREE_GB=2.0

# ── FFmpeg ──────────────────────────────────────────────────
MEDDOW_FFMPEG__TARGET_MB=45
MEDDOW_FFMPEG__MAX_SIZE_MB=49
MEDDOW_FFMPEG__LARGE_FILE_WARN_MB=200
MEDDOW_FFMPEG__HW_ACCEL=auto

# ── Proxy Pool ──────────────────────────────────────────────
MEDDOW_PROXY__ENABLED=false
MEDDOW_PROXY__FORCE_PROXY_PLATFORMS=youtube.com,youtu.be
MEDDOW_PROXY__ROTATION_STRATEGY=round_robin
MEDDOW_PROXY__HEALTH_CHECK_INTERVAL=300
MEDDOW_PROXY__MAX_CONSECUTIVE_FAILURES=3
MEDDOW_PROXY__DEAD_PROXY_COOLDOWN=600

# ── Cookies ─────────────────────────────────────────────────
MEDDOW_COOKIES__ENABLED=false
MEDDOW_COOKIES__COOKIES_DIR=/app/data/cookies
MEDDOW_COOKIES__YOUTUBE_COOKIE_FILE=youtube.txt

# ── Observability ───────────────────────────────────────────
MEDDOW_OBS__LOG_LEVEL=INFO
MEDDOW_OBS__METRICS_PORT=9090

# ── Docker PostgreSQL ───────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Reddit ──────────────────────────────────────────────────
MEDDOW_REDDIT__ENABLED=false
MEDDOW_REDDIT__CLIENT_ID=
MEDDOW_REDDIT__CLIENT_SECRET=
MEDDOW_REDDIT__USER_AGENT=MEDDOWBOT/1.0.0
