# ── Environment ─────────────────────────────────────────────
BOT_CONF_ENV=development

# ── Bot ─────────────────────────────────────────────────────
BOT_CONF_BOT__TOKEN=your_bot_token_here
BOT_CONF_BOT__WEBHOOK_URL=https://yourdomain.com
BOT_CONF_BOT__WEBHOOK_SECRET=generate_random_32_chars_here
BOT_CONF_BOT__ADMIN_IDS=your_telegram_user_id

# ── Local Bot API (removes 50MB limit) ──────────────────────
BOT_CONF_LOCAL_API__ENABLED=true
BOT_CONF_LOCAL_API__URL=http://telegram-bot-api:8081
BOT_CONF_LOCAL_API__API_ID=your_api_id_here
BOT_CONF_LOCAL_API__API_HASH=your_api_hash_here

# ── Database ────────────────────────────────────────────────
BOT_CONF_DATABASE__URL=sqlite+aiosqlite:///./dev.db
# Prod: postgresql+asyncpg://bot:password@postgres:5432/mediabot

# ── Redis ───────────────────────────────────────────────────
BOT_CONF_REDIS__URL=redis://localhost:6379/0

# ── Workers ─────────────────────────────────────────────────
BOT_CONF_WORKER__CONCURRENCY=3
BOT_CONF_WORKER__MAX_RETRIES=3
BOT_CONF_WORKER__RETRY_DELAY=30
BOT_CONF_WORKER__JOB_TIMEOUT=600

# ── Rate Limiting ───────────────────────────────────────────
BOT_CONF_RATE_LIMIT__REQUESTS_PER_MINUTE=10
BOT_CONF_RATE_LIMIT__BURST=3
BOT_CONF_RATE_LIMIT__MAX_CONCURRENT_JOBS=2

# ── Disk ────────────────────────────────────────────────────
BOT_CONF_DISK__DOWNLOADS_PATH=data/downloads
BOT_CONF_DISK__TEMP_PATH=data/temp
BOT_CONF_DISK__MAX_DISK_USAGE_GB=10.0
BOT_CONF_DISK__MIN_FREE_GB=2.0

# ── FFmpeg ──────────────────────────────────────────────────
BOT_CONF_FFMPEG__BINARY_PATH=ffmpeg
BOT_CONF_FFMPEG__TARGET_MB=45
BOT_CONF_FFMPEG__MAX_SIZE_MB=49
BOT_CONF_FFMPEG__LARGE_FILE_WARN_MB=200

# ── Proxy Pool ──────────────────────────────────────────────
BOT_CONF_DOWNLOADER_PROXIES__ENABLED=false
BOT_CONF_DOWNLOADER_PROXIES__FORCE_PROXY_PLATFORMS=youtube.com,youtu.be
BOT_CONF_DOWNLOADER_PROXIES__ROTATION_STRATEGY=round_robin
BOT_CONF_DOWNLOADER_PROXIES__HEALTH_CHECK_INTERVAL_SECONDS=300
BOT_CONF_DOWNLOADER_PROXIES__MAX_CONSECUTIVE_FAILURES=3
BOT_CONF_DOWNLOADER_PROXIES__DEAD_PROXY_COOLDOWN=600

# ── Cookies ─────────────────────────────────────────────────
BOT_CONF_COOKIES__ENABLED=false
BOT_CONF_COOKIES__COOKIES_DIR=data/cookies
BOT_CONF_COOKIES__VALIDATE_ON_STARTUP=false

# ── Observability ───────────────────────────────────────────
BOT_CONF_OBS__LOG_LEVEL=INFO
BOT_CONF_OBS__METRICS_PORT=9090

# ── Docker PostgreSQL ───────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Reddit ──────────────────────────────────────────────────
BOT_CONF_REDDIT__ENABLED=false
BOT_CONF_REDDIT__USER_AGENT=MEDDOWBOT/1.0.0
