# ── Environment ─────────────────────────────────────────────
ENV=development

# ── Bot ─────────────────────────────────────────────────────
BOT__TOKEN=your_bot_token_here
BOT__WEBHOOK_URL=https://yourdomain.com
BOT__WEBHOOK_SECRET=generate_random_32_chars_here
BOT__ADMIN_IDS=your_telegram_user_id

# ── Local Bot API (removes 50MB limit) ──────────────────────
LOCAL_API__ENABLED=true
LOCAL_API__URL=http://telegram-bot-api:8081
LOCAL_API__API_ID=your_api_id_here
LOCAL_API__API_HASH=your_api_hash_here

# ── Database ────────────────────────────────────────────────
DATABASE__URL=sqlite+aiosqlite:///./dev.db
# Prod: postgresql+asyncpg://bot:password@postgres:5432/mediabot

# ── Redis ───────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379/0

# ── Workers ─────────────────────────────────────────────────
WORKER__CONCURRENCY=3
WORKER__MAX_RETRIES=3
WORKER__RETRY_DELAY=30
WORKER__JOB_TIMEOUT=600

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT__PER_HOUR=10
RATE_LIMIT__BURST=3
RATE_LIMIT__MAX_CONCURRENT_JOBS=2

# ── Disk ────────────────────────────────────────────────────
DISK__TMP_DIR=/tmp/bot
DISK__MIN_FREE_GB=2.0

# ── FFmpeg ──────────────────────────────────────────────────
FFMPEG__TARGET_MB=45
FFMPEG__MAX_SIZE_MB=49
FFMPEG__LARGE_FILE_WARN_MB=200
FFMPEG__HW_ACCEL=auto

# ── Proxy Pool ──────────────────────────────────────────────
PROXY__ENABLED=false
PROXY__FORCE_PROXY_PLATFORMS=youtube.com,youtu.be
PROXY__ROTATION_STRATEGY=round_robin
PROXY__HEALTH_CHECK_INTERVAL=300
PROXY__MAX_CONSECUTIVE_FAILURES=3
PROXY__DEAD_PROXY_COOLDOWN=600

# ── Cookies ─────────────────────────────────────────────────
COOKIES__ENABLED=false
COOKIES__COOKIES_DIR=/app/data/cookies
COOKIES__YOUTUBE_COOKIE_FILE=youtube.txt

# ── Observability ───────────────────────────────────────────
OBS__LOG_LEVEL=INFO
OBS__METRICS_PORT=9090

# ── Docker PostgreSQL ───────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Reddit ──────────────────────────────────────────────────
REDDIT__ENABLED=false
REDDIT__CLIENT_ID=
REDDIT__CLIENT_SECRET=
REDDIT__USER_AGENT=MEDDOWBOT/1.0.0
