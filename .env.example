# ── Environment ─────────────────────────────────────────────
MEDDOW_ENV=development

# ── Bot ─────────────────────────────────────────────────────
MEDDOW_BOT_TOKEN=your_bot_token_here
MEDDOW_BOT_ADMIN_IDS=your_telegram_user_id
MEDDOW_BOT_WEBHOOK_URL=https://yourdomain.com
MEDDOW_BOT_WEBHOOK_SECRET=generate_random_32_chars_here

# ── Local Bot API (removes 50MB limit) ──────────────────────
MEDDOW_LOCAL_API_ENABLED=true
MEDDOW_LOCAL_API_URL=http://telegram-bot-api:8081
MEDDOW_LOCAL_API_API_ID=your_api_id_here
MEDDOW_LOCAL_API_API_HASH=your_api_hash_here

# ── Database ────────────────────────────────────────────────
MEDDOW_DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Prod: postgresql+asyncpg://bot:password@postgres:5432/mediabot

# ── Redis ───────────────────────────────────────────────────
MEDDOW_REDIS_URL=redis://localhost:6379/0

# ── Workers ─────────────────────────────────────────────────
MEDDOW_WORKER_CONCURRENCY=3

# ── Rate Limiting ───────────────────────────────────────────
MEDDOW_RATE_LIMIT_REQUESTS_PER_MINUTE=10
MEDDOW_RATE_LIMIT_BURST=3
MEDDOW_RATE_LIMIT_MAX_CONCURRENT_JOBS=2

# ── Disk ────────────────────────────────────────────────────
MEDDOW_DISK_MIN_FREE_GB=2.0

# ── FFmpeg ──────────────────────────────────────────────────
MEDDOW_FFMPEG_TARGET_MB=45
MEDDOW_FFMPEG_MAX_SIZE_MB=49
MEDDOW_FFMPEG_LARGE_FILE_WARN_MB=200

# ── Proxy Pool ──────────────────────────────────────────────
MEDDOW_PROXY_ENABLED=false
MEDDOW_PROXY_ROTATION_STRATEGY=round_robin

# ── Cookies ─────────────────────────────────────────────────
MEDDOW_COOKIES_ENABLED=false

# ── Observability ───────────────────────────────────────────
MEDDOW_OBS_LOG_LEVEL=INFO
MEDDOW_OBS_METRICS_PORT=9090

# ── Docker PostgreSQL ───────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here
